# Configuración de base de datos SQL Server
DB_SERVER=servidor
DB_NAME=nombre_base_datos
DB_USER=usuario_db
DB_PASS=contraseña_db

# Seguridad - Se genera una clave con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=tu_clave_secreta_generada_aqui
SESSION_TIMEOUT=30
MAX_LOGIN_ATTEMPTS=5